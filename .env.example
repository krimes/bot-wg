# --- Telegram ---
# Токен от @BotFather
BOT_TOKEN=123456:AAA-replace-me

# Список Telegram-ID администраторов через запятую.
# Узнать свой ID: напишите боту @userinfobot
ADMIN_IDS=111111111,222222222

# --- AmneziaWG (Docker) ---
# Имя контейнера, в котором крутится AmneziaWG
AWG_CONTAINER=amnezia-awg

# Имя интерфейса внутри контейнера
AWG_INTERFACE=wg0

# Путь к конфигу сервера внутри контейнера
AWG_CONFIG_PATH=/opt/amnezia/awg/wg0.conf

# Путь к clientsTable — список клиентов, который читает GUI AmneziaVPN.
# Если оставить пустым, бот не будет синхронизировать список с GUI.
AWG_CLIENTS_TABLE_PATH=/opt/amnezia/awg/clientsTable

# Публичный endpoint (host:port), который попадёт в клиентский конфиг.
# Можно указать FQDN или IP, порт берётся из ListenPort сервера если оставить пустым.
AWG_ENDPOINT_HOST=vpn.example.com
AWG_ENDPOINT_PORT=51820

# Подсеть для клиентов (откуда выделяются IP). Должна совпадать с серверной.
AWG_CLIENT_SUBNET=10.8.1.0/24

# DNS для клиентов
AWG_CLIENT_DNS=1.1.1.1,1.0.0.1

# AllowedIPs у клиента: 0.0.0.0/0,::/0 — заворачиваем весь трафик
AWG_CLIENT_ALLOWED_IPS=0.0.0.0/0,::/0

# Keep-alive в секундах (0 — не использовать)
AWG_CLIENT_KEEPALIVE=25

# --- Bot data ---
DB_PATH=/var/lib/awg-bot/awg-bot.db
